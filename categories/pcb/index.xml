&lt;table&gt;
  &lt;thead&gt;
      &lt;tr&gt;
          &lt;th&gt;引脚&lt;/th&gt;
          &lt;th&gt;电路连接&lt;/th&gt;
          &lt;th&gt;核心作用&lt;/th&gt;
      &lt;/tr&gt;
  &lt;/thead&gt;
  &lt;tbody&gt;
      &lt;tr&gt;
          &lt;td&gt;&lt;code&gt;PA13(SWCLK)&lt;/code&gt;&lt;/td&gt;
          &lt;td&gt;10kΩ上拉电阻R4接3V3_MCU，SWD时钟线&lt;/td&gt;
          &lt;td&gt;SWD调试接口的时钟信号，配合SWDIO实现程序烧录、在线调试&lt;/td&gt;
      &lt;/tr&gt;
      &lt;tr&gt;
          &lt;td&gt;&lt;code&gt;PA14(SWDIO)&lt;/code&gt;&lt;/td&gt;
          &lt;td&gt;10kΩ上拉电阻R5接3V3_MCU，SWD数据线&lt;/td&gt;
          &lt;td&gt;SWD调试接口的数据信号，与调试器（GAPLINK）通信，下载/调试程序&lt;/td&gt;
      &lt;/tr&gt;
  &lt;/tbody&gt;
&lt;/table&gt;
&lt;h3 id=&#34;24-电机控制pwm输出电路&#34;&gt;2.4 电机控制：PWM输出电路
&lt;/h3&gt;&lt;p&gt;&lt;img src=&#34;https://jeffrey-ljf.github.io/p/%E7%89%A9%E8%81%94%E7%BD%91%E5%BC%80%E5%8F%91%E6%9D%BF%E5%88%9D%E4%BD%93%E9%AA%8C/Motor.png&#34;
