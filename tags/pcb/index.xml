        <description>&lt;img src="https://jeffrey-ljf.github.io/p/%E7%89%A9%E8%81%94%E7%BD%91%E5%BC%80%E5%8F%91%E6%9D%BF%E5%88%9D%E4%BD%93%E9%AA%8C/%E6%B5%B7%E6%8A%A5.png" alt="Featured image of post 物联网开发板初体验" /&gt;&lt;hr&gt;
&lt;h2 id=&#34;基础功能引脚电路非通用gpio&#34;&gt;基础功能引脚电路（非通用GPIO）
&lt;/h2&gt;&lt;p&gt;下面引脚是MCU的核心功能引脚，不属于普通GPIO，是系统稳定运行的基础：&lt;/p&gt;
&lt;p&gt;&lt;img src=&#34;https://jeffrey-ljf.github.io/p/%E7%89%A9%E8%81%94%E7%BD%91%E5%BC%80%E5%8F%91%E6%9D%BF%E5%88%9D%E4%BD%93%E9%AA%8C/MCU.png&#34;
	width=&#34;3384&#34;
	height=&#34;1720&#34;
	srcset=&#34;https://jeffrey-ljf.github.io/p/%E7%89%A9%E8%81%94%E7%BD%91%E5%BC%80%E5%8F%91%E6%9D%BF%E5%88%9D%E4%BD%93%E9%AA%8C/MCU_hu_fc6e2b45e8da7e5e.png 480w, https://jeffrey-ljf.github.io/p/%E7%89%A9%E8%81%94%E7%BD%91%E5%BC%80%E5%8F%91%E6%9D%BF%E5%88%9D%E4%BD%93%E9%AA%8C/MCU_hu_f2f1bb7a6544b2bd.png 1024w&#34;
	loading=&#34;lazy&#34;
	
		alt=&#34;MCU电路设计&#34;
	
	
		class=&#34;gallery-image&#34; 
		data-flex-grow=&#34;196&#34;
		data-flex-basis=&#34;472px&#34;
	
&gt;&lt;/p&gt;
&lt;p&gt;电路设计关键亮点总结&lt;/p&gt;
&lt;table&gt;
  &lt;thead&gt;
      &lt;tr&gt;
          &lt;th&gt;设计点&lt;/th&gt;
          &lt;th&gt;实现方式&lt;/th&gt;
          &lt;th&gt;优势&lt;/th&gt;
      &lt;/tr&gt;
  &lt;/thead&gt;
  &lt;tbody&gt;
      &lt;tr&gt;
          &lt;td&gt;单点接地&lt;/td&gt;
          &lt;td&gt;数字地/模拟地通过0Ω电阻单点连接&lt;/td&gt;
          &lt;td&gt;减少数字噪声对ADC采样的干扰，提高模拟采样精度&lt;/td&gt;
      &lt;/tr&gt;
      &lt;tr&gt;
          &lt;td&gt;电源去耦&lt;/td&gt;
          &lt;td&gt;每个VDD引脚配0.1μF去耦电容，总线增加滤波&lt;/td&gt;
          &lt;td&gt;滤除电源高频噪声，避免MCU因电源波动死机&lt;/td&gt;
      &lt;/tr&gt;
      &lt;tr&gt;
          &lt;td&gt;状态稳定&lt;/td&gt;
          &lt;td&gt;关键引脚（NRST、BOOT0、SWD）加上下拉电阻&lt;/td&gt;
          &lt;td&gt;防止引脚浮空导致的误触发、异常复位&lt;/td&gt;
      &lt;/tr&gt;
      &lt;tr&gt;
          &lt;td&gt;多串口复用&lt;/td&gt;
          &lt;td&gt;3个USART分别用于调试、WIFI、485&lt;/td&gt;
          &lt;td&gt;满足不同通信场景需求，适配物联网、工业控制&lt;/td&gt;
      &lt;/tr&gt;
      &lt;tr&gt;
          &lt;td&gt;电机驱动预留&lt;/td&gt;
          &lt;td&gt;高级定时器PWM输出&lt;/td&gt;
          &lt;td&gt;支持无刷电机FOC控制，适配嵌入式电机开发需求&lt;/td&gt;
      &lt;/tr&gt;
  &lt;/tbody&gt;
&lt;/table&gt;
&lt;h3 id=&#34;11-时钟系统引脚&#34;&gt;1.1 时钟系统引脚
&lt;/h3&gt;&lt;table&gt;
  &lt;thead&gt;
      &lt;tr&gt;
          &lt;th&gt;引脚&lt;/th&gt;
          &lt;th&gt;电路连接&lt;/th&gt;
          &lt;th&gt;核心作用&lt;/th&gt;
      &lt;/tr&gt;
  &lt;/thead&gt;
  &lt;tbody&gt;
      &lt;tr&gt;
          &lt;td&gt;&lt;code&gt;OSC_IN / OSC_OUT&lt;/code&gt;&lt;/td&gt;
          &lt;td&gt;外接8MHz晶振X1，配合22pF负载电容C1、C2组成&lt;strong&gt;外部高速晶振（HSE）电路&lt;/strong&gt;&lt;/td&gt;
          &lt;td&gt;为MCU提供8MHz外部时钟源，经内部PLL倍频生成72MHz系统时钟，是MCU运行的核心时钟&lt;/td&gt;
      &lt;/tr&gt;
      &lt;tr&gt;
          &lt;td&gt;&lt;code&gt;PC14-OSC32_IN / PC15-OSC32_OUT&lt;/code&gt;&lt;/td&gt;
          &lt;td&gt;原理图预留32.768kHz晶振接口（未焊接），属于&lt;strong&gt;外部低速晶振（LSE）&lt;/strong&gt;&lt;/td&gt;
          &lt;td&gt;为RTC实时时钟提供时钟，主电源掉电时由VBAT供电，保持时间和备份寄存器数据&lt;/td&gt;
      &lt;/tr&gt;
      &lt;tr&gt;
          &lt;td&gt;&lt;code&gt;VBAT&lt;/code&gt;&lt;/td&gt;
          &lt;td&gt;接3V3_MCU（或备用电池）&lt;/td&gt;
          &lt;td&gt;为RTC、备份寄存器供电，主电源掉电时维持RTC运行，避免时间丢失&lt;/td&gt;
      &lt;/tr&gt;
  &lt;/tbody&gt;
&lt;/table&gt;
&lt;h3 id=&#34;12-复位与启动模式引脚&#34;&gt;1.2 复位与启动模式引脚
&lt;/h3&gt;&lt;table&gt;
  &lt;thead&gt;
      &lt;tr&gt;
          &lt;th&gt;引脚&lt;/th&gt;
          &lt;th&gt;电路连接&lt;/th&gt;
          &lt;th&gt;核心作用&lt;/th&gt;
      &lt;/tr&gt;
  &lt;/thead&gt;
  &lt;tbody&gt;
      &lt;tr&gt;
          &lt;td&gt;&lt;code&gt;NRST&lt;/code&gt;&lt;/td&gt;
          &lt;td&gt;10kΩ上拉电阻R35接3V3_MCU，外接复位按键SW1，配合YT581SSJG复位监控芯片&lt;/td&gt;
          &lt;td&gt;MCU复位引脚（低电平有效）：上拉保证正常工作为高电平，按键按下拉低触发复位；监控芯片实现上电/掉电复位，防止异常死机&lt;/td&gt;
      &lt;/tr&gt;
      &lt;tr&gt;
          &lt;td&gt;&lt;code&gt;BOOT0(PB8)&lt;/code&gt;&lt;/td&gt;
          &lt;td&gt;10kΩ下拉电阻R2接地&lt;/td&gt;
          &lt;td&gt;启动模式选择引脚：下拉为0时，默认&lt;strong&gt;主闪存启动&lt;/strong&gt;（正常运行程序）；拉高为1时，进入串口下载模式&lt;/td&gt;
      &lt;/tr&gt;
      &lt;tr&gt;
          &lt;td&gt;&lt;code&gt;BOOT1(PB2)&lt;/code&gt;&lt;/td&gt;
          &lt;td&gt;原理图悬空（默认下拉）&lt;/td&gt;
          &lt;td&gt;配合BOOT0选择启动模式，默认0，与BOOT0下拉组合为主闪存启动&lt;/td&gt;
      &lt;/tr&gt;
  &lt;/tbody&gt;
&lt;/table&gt;
&lt;h3 id=&#34;13-电源与接地引脚&#34;&gt;1.3 电源与接地引脚
&lt;/h3&gt;&lt;table&gt;
  &lt;thead&gt;
      &lt;tr&gt;
          &lt;th&gt;引脚&lt;/th&gt;
          &lt;th&gt;电路连接&lt;/th&gt;
          &lt;th&gt;核心作用&lt;/th&gt;
      &lt;/tr&gt;
  &lt;/thead&gt;
  &lt;tbody&gt;
      &lt;tr&gt;
          &lt;td&gt;&lt;code&gt;VDD_1~VDD_4 / VDDA&lt;/code&gt;&lt;/td&gt;
          &lt;td&gt;统一接3V3_MCU，每个引脚旁接0.1μF（104）去耦电容，电源总线增加多组104滤波电容&lt;/td&gt;
          &lt;td&gt;为MCU内核、I/O、ADC等模块供电；去耦电容滤除电源高频噪声，保证供电稳定&lt;/td&gt;
      &lt;/tr&gt;
      &lt;tr&gt;
          &lt;td&gt;&lt;code&gt;VSS_1~VSS_4 / VSSA&lt;/code&gt;&lt;/td&gt;
          &lt;td&gt;数字地与模拟地通过0Ω电阻R3&lt;strong&gt;单点连接&lt;/strong&gt;&lt;/td&gt;
          &lt;td&gt;电源参考地，模拟地VSSA为ADC提供干净参考，减少数字噪声对模拟采样的干扰&lt;/td&gt;
      &lt;/tr&gt;
  &lt;/tbody&gt;
&lt;/table&gt;
&lt;hr&gt;
&lt;h2 id=&#34;通用gpio功能电路按模块分类&#34;&gt;通用GPIO功能电路（按模块分类）
&lt;/h2&gt;&lt;h3 id=&#34;21-人机交互led状态指示电路&#34;&gt;2.1 人机交互：LED状态指示电路
&lt;/h3&gt;&lt;p&gt;&lt;img src=&#34;https://jeffrey-ljf.github.io/p/%E7%89%A9%E8%81%94%E7%BD%91%E5%BC%80%E5%8F%91%E6%9D%BF%E5%88%9D%E4%BD%93%E9%AA%8C/RGB_MOS.png&#34;
	width=&#34;1674&#34;
	height=&#34;1623&#34;
	srcset=&#34;https://jeffrey-ljf.github.io/p/%E7%89%A9%E8%81%94%E7%BD%91%E5%BC%80%E5%8F%91%E6%9D%BF%E5%88%9D%E4%BD%93%E9%AA%8C/RGB_MOS_hu_a8ec786781a91327.png 480w, https://jeffrey-ljf.github.io/p/%E7%89%A9%E8%81%94%E7%BD%91%E5%BC%80%E5%8F%91%E6%9D%BF%E5%88%9D%E4%BD%93%E9%AA%8C/RGB_MOS_hu_ba83e9daccffbf41.png 1024w&#34;
	loading=&#34;lazy&#34;
	
		alt=&#34;RGB&#34;
	
	
		class=&#34;gallery-image&#34; 
		data-flex-grow=&#34;103&#34;
		data-flex-basis=&#34;247px&#34;
	
&gt;&lt;/p&gt;
&lt;table&gt;
  &lt;thead&gt;
      &lt;tr&gt;
          &lt;th&gt;引脚&lt;/th&gt;
          &lt;th&gt;电路连接&lt;/th&gt;
          &lt;th&gt;核心作用&lt;/th&gt;
      &lt;/tr&gt;
  &lt;/thead&gt;
  &lt;tbody&gt;
      &lt;tr&gt;
          &lt;td&gt;&lt;code&gt;PA1&lt;/code&gt;&lt;/td&gt;
          &lt;td&gt;推挽输出，接红色LED（LED_R）&lt;/td&gt;
          &lt;td&gt;控制红色LED亮灭：输出低电平时点亮，高电平时熄灭，用于告警、故障状态指示&lt;/td&gt;
      &lt;/tr&gt;
      &lt;tr&gt;
          &lt;td&gt;&lt;code&gt;PA2&lt;/code&gt;&lt;/td&gt;
          &lt;td&gt;推挽输出，接绿色LED（LED_G）&lt;/td&gt;
          &lt;td&gt;控制绿色LED亮灭，用于系统正常运行、通信正常等状态指示&lt;/td&gt;
      &lt;/tr&gt;
      &lt;tr&gt;
          &lt;td&gt;&lt;code&gt;PA6&lt;/code&gt;&lt;/td&gt;
          &lt;td&gt;推挽输出，接蓝色LED（LED_B）&lt;/td&gt;
          &lt;td&gt;控制蓝色LED亮灭，用于自定义状态（如配置完成、数据传输）指示&lt;/td&gt;
      &lt;/tr&gt;
  &lt;/tbody&gt;
&lt;/table&gt;
&lt;h3 id=&#34;22-通信接口串口与485控制电路&#34;&gt;2.2 通信接口：串口与485控制电路
&lt;/h3&gt;&lt;p&gt;STM32F103内置3个USART，原理图中分别用于不同通信场景：&lt;/p&gt;
&lt;table&gt;
  &lt;thead&gt;
      &lt;tr&gt;
          &lt;th&gt;接口&lt;/th&gt;
          &lt;th&gt;涉及引脚&lt;/th&gt;
          &lt;th&gt;电路连接&lt;/th&gt;
          &lt;th&gt;核心作用&lt;/th&gt;
      &lt;/tr&gt;
  &lt;/thead&gt;
  &lt;tbody&gt;
      &lt;tr&gt;
          &lt;td&gt;USART1（调试串口）&lt;/td&gt;
          &lt;td&gt;&lt;code&gt;PA9(TX1) / PA10(RX1)&lt;/code&gt;&lt;/td&gt;
          &lt;td&gt;连接USB转串口电路，对接上位机&lt;/td&gt;
          &lt;td&gt;用于打印调试日志、接收上位机指令，是开发调试的核心串口&lt;/td&gt;
      &lt;/tr&gt;
      &lt;tr&gt;
          &lt;td&gt;USART2（WIFI串口）&lt;/td&gt;
          &lt;td&gt;&lt;code&gt;PA2(TX2) / PA3(RX2)&lt;/code&gt;&lt;/td&gt;
          &lt;td&gt;连接WIFI模块（如ESP8266）&lt;/td&gt;
          &lt;td&gt;实现无线通信，透传数据到云端/上位机，用于物联网场景&lt;/td&gt;
      &lt;/tr&gt;
      &lt;tr&gt;
          &lt;td&gt;USART3（扩展串口）&lt;/td&gt;
          &lt;td&gt;&lt;code&gt;PB10(TX3) / PB11(RX3)&lt;/code&gt;&lt;/td&gt;
          &lt;td&gt;预留/外接485/蓝牙模块&lt;/td&gt;
          &lt;td&gt;扩展串口资源，用于工业通信、外设连接&lt;/td&gt;
      &lt;/tr&gt;
      &lt;tr&gt;
          &lt;td&gt;485收发控制&lt;/td&gt;
          &lt;td&gt;&lt;code&gt;PA4(485_SELECT)&lt;/code&gt;&lt;/td&gt;
          &lt;td&gt;推挽输出，控制RS485芯片DE/RE引脚&lt;/td&gt;
          &lt;td&gt;RS485半双工通信的方向控制：高电平发送、低电平接收，实现远距离工业总线通信&lt;/td&gt;
      &lt;/tr&gt;
  &lt;/tbody&gt;
&lt;/table&gt;
&lt;p&gt;&lt;img src=&#34;https://jeffrey-ljf.github.io/p/%E7%89%A9%E8%81%94%E7%BD%91%E5%BC%80%E5%8F%91%E6%9D%BF%E5%88%9D%E4%BD%93%E9%AA%8C/DPLink.png&#34;
